{
  "schema": "msys.manifest.v1",
  "package": {
    "id": "org.msys.settings",
    "name": "MSYS Settings",
    "version": "0.4.4",
    "kind": "application",
    "vendor": "MSYS",
    "summary": "System, connectivity, audio, display, role, HAL, update, and rollback settings",
    "x-msys-i18n": {
      "catalog": "files/share/i18n/catalog.json",
      "name_key": "app.name",
      "summary_key": "app.summary"
    },
    "icons": [
      {
        "size": 32,
        "mime": "image/x-portable-pixmap",
        "path": "files/share/icons/settings.ppm"
      }
    ]
  },
  "components": [
    {
      "id": "main",
      "name": "Settings",
      "runtime": "tk",
      "exec": [
        "python",
        "@package/files/app/main.py"
      ],
      "lifecycle": "manual",
      "restart": "never",
      "env": {
        "PYTHONUNBUFFERED": "1"
      },
      "readiness": {
        "mode": "mipc-ready",
        "timeout_ms": 8000
      },
      "provides": [
        {
          "interface": "org.msys.application-navigation.v1",
          "exclusive": false,
          "priority": 100
        },
        {
          "interface": "org.msys.settings.regional.v1",
          "exclusive": false,
          "priority": 100
        },
        {
          "interface": "org.msys.settings.frontend.v1",
          "exclusive": false,
          "priority": 100
        }
      ],
      "permissions": [
        "display:x11",
        "mipc.call:msys.core",
        "mipc.call:role:window-manager",
        "mipc.call:role:launcher",
        "mipc.call:role:update-agent",
        "mipc.call:role:install-agent",
        "mipc.call:role:input-method",
        "mipc.call:role:audio-manager",
        "mipc.call:role:storage",
        "mipc.call:org.msys.hal.manager.v1",
        "mipc.call:org.msys.hal.ch347-control.v1",
        "mipc.event:subscribe:msys.activation",
        "mipc.event:subscribe:msys.hal.changed",
        "mipc.event:subscribe:msys.shell.preferences.changed",
        "mipc.event:subscribe:msys.layout.changed",
        "mipc.event:subscribe:msys.session.preferences.changed",
        "mipc.event:subscribe:msys.update.checked",
        "mipc.event:subscribe:msys.update.applied",
        "mipc.event:subscribe:msys.update.error",
        "mipc.event:subscribe:msys.install.package_changed",
        "mipc.event:subscribe:msys.install.error",
        "mipc.event:subscribe:msys.display.migration",
        "mipc.event:subscribe:msys.audio.changed",
        "mipc.event:subscribe:msys.hal.storage.changed"
      ],
      "isolation": "baseline",
      "windowing": {
        "system": "x11",
        "display": "inherit",
        "mode": "window",
        "title": "MSYS Settings",
        "identity": {
          "app_id": "org.msys.settings",
          "x11_wm_class": "org.msys.settings",
          "x11_wm_instance": "main"
        }
      },
      "activation": {
        "launchable": true,
        "intents": [
          {
            "action": "settings-panel",
            "name": "system",
            "priority": 100
          },
          {
            "action": "settings-panel",
            "name": "layout",
            "priority": 100
          },
          {
            "action": "settings-panel",
            "name": "display",
            "priority": 100
          },
          {
            "action": "settings-panel",
            "name": "wifi",
            "priority": 100
          },
          {
            "action": "settings-panel",
            "name": "bluetooth",
            "priority": 100
          },
          {
            "action": "settings-panel",
            "name": "audio",
            "priority": 100
          },
          {
            "action": "settings-panel",
            "name": "appearance",
            "priority": 100
          },
          {
            "action": "settings-panel",
            "name": "apps",
            "priority": 100
          },
          {
            "action": "settings-panel",
            "name": "storage",
            "priority": 100
          },
          {
            "action": "settings-panel",
            "name": "roles",
            "priority": 100
          },
          {
            "action": "settings-panel",
            "name": "hal",
            "priority": 100
          },
          {
            "action": "settings-panel",
            "name": "updates",
            "priority": 100
          },
          {
            "action": "settings-panel",
            "name": "regional",
            "priority": 100
          }
        ]
      },
      "x-msys-ui-provider": {
        "id": "tk",
        "default": true
      }
    },
    {
      "id": "main-lvgl",
      "name": "Settings (LVGL preview)",
      "runtime": "native",
      "exec": [
        "@package/files/bin/msys-settings-lvgl",
        "--bridge",
        "@package/files/app/lvgl_bridge.py",
        "--python",
        "@supervisor-python",
        "--ui",
        "@package/files/share/ui/settings.xml",
        "--output",
        "spi"
      ],
      "lifecycle": "manual",
      "restart": "never",
      "readiness": {
        "mode": "mipc-ready",
        "timeout_ms": 12000
      },
      "provides": [
        {
          "interface": "org.msys.settings.frontend.v1",
          "exclusive": false,
          "priority": 90
        }
      ],
      "permissions": [
        "display:x11",
        "mipc.call:msys.core",
        "mipc.call:role:window-manager",
        "mipc.call:role:launcher",
        "mipc.call:role:input-method",
        "mipc.call:role:audio-manager",
        "mipc.call:role:storage",
        "mipc.call:role:install-agent",
        "mipc.call:org.msys.hal.manager.v1",
        "mipc.event:subscribe:msys.shell.preferences.changed",
        "mipc.event:subscribe:msys.layout.changed"
      ],
      "isolation": "baseline",
      "windowing": {
        "system": "x11",
        "display": "inherit",
        "mode": "window",
        "title": "MSYS 设置",
        "identity": {
          "app_id": "org.msys.settings",
          "x11_wm_class": "org.msys.settings",
          "x11_wm_instance": "main-lvgl"
        }
      },
      "activation": {
        "launchable": false
      },
      "x-msys-ui-provider": {
        "id": "lvgl",
        "fallback_component": "org.msys.settings:main",
        "phase": "preview"
      }
    },
    {
      "id": "software-center",
      "name": "Software Center",
      "runtime": "native",
      "exec": [
        "@package/files/bin/msys-settings-lvgl",
        "--mode",
        "software-center",
        "--bridge",
        "@package/files/app/lvgl_bridge.py",
        "--python",
        "@supervisor-python",
        "--ui",
        "@package/files/share/ui/software-center.xml",
        "--output",
        "spi"
      ],
      "lifecycle": "manual",
      "restart": "never",
      "env": {
        "PYTHONUNBUFFERED": "1",
        "MSYS_SETTINGS_MODE": "software-center"
      },
      "readiness": {
        "mode": "mipc-ready",
        "timeout_ms": 12000
      },
      "provides": [
        {
          "interface": "org.msys.application-navigation.v1",
          "exclusive": false,
          "priority": 100
        }
      ],
      "permissions": [
        "display:x11",
        "mipc.call:msys.core",
        "mipc.call:role:update-agent",
        "mipc.call:role:install-agent",
        "mipc.event:subscribe:msys.activation",
        "mipc.event:subscribe:msys.update.checked",
        "mipc.event:subscribe:msys.update.applied",
        "mipc.event:subscribe:msys.update.error",
        "mipc.event:subscribe:msys.install.package_changed",
        "mipc.event:subscribe:msys.install.error"
      ],
      "isolation": "baseline",
      "windowing": {
        "system": "x11",
        "display": "inherit",
        "mode": "window",
        "title": "MSYS Software Center",
        "identity": {
          "app_id": "org.msys.software-center",
          "x11_wm_class": "org.msys.software-center",
          "x11_wm_instance": "software-center"
        }
      },
      "activation": {
        "launchable": true,
        "intents": [
          {
            "action": "software-center",
            "name": "apps",
            "priority": 100
          },
          {
            "action": "software-center",
            "name": "updates",
            "priority": 100
          },
          {
            "action": "software-center",
            "name": "details",
            "priority": 100
          },
          {
            "action": "software-center",
            "name": "uninstall",
            "priority": 100
          }
        ]
      },
      "x-msys-i18n": {
        "catalog": "files/share/i18n/catalog.json",
        "name_key": "software_center.name",
        "summary_key": "software_center.summary"
      },
      "icons": [
        {
          "size": 32,
          "mime": "image/x-portable-pixmap",
          "path": "files/share/icons/settings.ppm"
        }
      ],
      "x-msys-ui-provider": {
        "id": "lvgl",
        "default": true,
        "fallback_component": "org.msys.settings:software-center-tk"
      }
    },
    {
      "id": "software-center-tk",
      "name": "Software Center (Tk fallback)",
      "runtime": "tk",
      "exec": [
        "python",
        "@package/files/app/main.py"
      ],
      "lifecycle": "manual",
      "restart": "never",
      "env": {
        "PYTHONUNBUFFERED": "1",
        "MSYS_SETTINGS_MODE": "software-center"
      },
      "readiness": {
        "mode": "mipc-ready",
        "timeout_ms": 8000
      },
      "permissions": [
        "display:x11",
        "mipc.call:msys.core",
        "mipc.call:role:update-agent",
        "mipc.call:role:install-agent",
        "mipc.event:subscribe:msys.activation",
        "mipc.event:subscribe:msys.update.checked",
        "mipc.event:subscribe:msys.update.applied",
        "mipc.event:subscribe:msys.update.error",
        "mipc.event:subscribe:msys.install.package_changed",
        "mipc.event:subscribe:msys.install.error"
      ],
      "isolation": "baseline",
      "windowing": {
        "system": "x11",
        "display": "inherit",
        "mode": "window",
        "title": "MSYS Software Center",
        "identity": {
          "app_id": "org.msys.software-center",
          "x11_wm_class": "org.msys.software-center",
          "x11_wm_instance": "software-center-tk"
        }
      },
      "activation": {
        "launchable": false
      },
      "x-msys-ui-provider": {
        "id": "tk",
        "fallback_for": "org.msys.settings:software-center"
      }
    }
  ]
}
